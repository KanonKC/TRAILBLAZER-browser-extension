{
  "manifest_version": 3,
  "name": "TRAILBLAZER – Twitch Token Sync",
  "version": "1.0.0",
  "description": "Automatically syncs your Twitch session token with TRAILBLAZER to enable automated video export.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "cookies",
    "storage",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://*.twitch.tv/*",
    "https://trailblazer-api.kanonkc.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TRAILBLAZER Token Sync"
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["Content.js"],
      "run_at": "document_idle"
    }
  ]
}
